rules_version = '2';

// ════════════════════════════════════════════════════════════════
//  ৪ ইঞ্জিনিয়ার ব্যাটালিয়ন — Firestore Security Rules v2.1
//  Firebase Console → Firestore → Rules এ paste করুন।
//
//  v2.1 পরিবর্তন:
//  ✅ registrations collection যোগ — নিবন্ধন যাচাইয়ের জন্য publicly readable
//  ✅ users/create — member নিজে doc তৈরি করতে পারবে (role ছাড়া)
// ════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──────────────────────────────────────

    // Authenticated + NOT anonymous
    function isAuth() {
      return request.auth != null && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // Role read helper — role না থাকলে default 'member'
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'member');
    }

    function isSuperAdmin() {
      return isAuth() && getUserRole() == 'superadmin';
    }

    function isAdmin() {
      return isAuth() && getUserRole() in ['admin', 'superadmin'];
    }

    function isSubAdmin() {
      return isAuth() && getUserRole() == 'subadmin';
    }

    function isAnyAdmin() {
      return isAuth() && getUserRole() in ['admin', 'superadmin', 'subadmin'];
    }

    function isMemberRole() {
      return isAuth() && getUserRole() == 'member';
    }

    // Admin এর assigned company
    function adminCompany() {
      return get(/databases/$(database)/documents/adminProfiles/$(request.auth.uid)).data.get('co_bn', '');
    }

    function isAdminOfCompany(co) {
      return isAdmin() && (isSuperAdmin() || adminCompany() == co);
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Document size check
    function isReasonableSize() {
      return request.resource.data.keys().size() <= 60;
    }

    // ─────────────────────────────────────────────────────────
    //  registrations collection
    //  নিবন্ধন যাচাইয়ের জন্য — auth ছাড়াই পড়া যাবে
    //  শুধু dob ও registered flag থাকে — sensitive data নেই
    // ─────────────────────────────────────────────────────────
    match /registrations/{armyId} {
      // ✅ যে কেউ পড়তে পারবে — নিবন্ধন যাচাইয়ের জন্য
      allow read: if true;

      // শুধু Admin তৈরি/আপডেট করবে
      allow create, update: if isAdmin() && isReasonableSize();

      // নিবন্ধন সফল হলে member নিজে registered:true করতে পারবে
      allow update: if isAuth() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['registered', 'registeredAt', 'uid']);

      allow delete: if isSuperAdmin();
    }

    // ─────────────────────────────────────────────────────────
    //  members collection
    // ─────────────────────────────────────────────────────────
    match /members/{memberId} {
      // Read: authenticated non-anonymous only
      allow read: if isAuth();

      // Create: admin/superadmin only (not subadmin)
      allow create: if isAdmin() && isReasonableSize();

      // Update: superadmin সব, admin শুধু নিজের company
      allow update: if isAdmin() && isReasonableSize() &&
        (isSuperAdmin() ||
         isAdminOfCompany(resource.data.get('co_bn','')) ||
         isAdminOfCompany(resource.data.get('co_en','')));

      // member নিজে নিজের doc update করতে পারবে (setup/profile fill)
      allow update: if isAuth() &&
        request.auth.uid != null &&
        isReasonableSize() &&
        !('dob' in request.resource.data.diff(resource.data).affectedKeys()) &&
        !('no'  in request.resource.data.diff(resource.data).affectedKeys());

      // Delete: superadmin only
      allow delete: if isSuperAdmin();

      // leaves subcollection
      match /leaves/{leaveId} {
        allow read: if isAuth();
        allow create, update: if isAuth() && !isSubAdmin();
        allow delete: if isAdmin();
      }
    }

    // ─────────────────────────────────────────────────────────
    //  users collection
    // ─────────────────────────────────────────────────────────
    match /users/{userId} {
      // নিজের doc পড়তে পারবে, admin সব দেখবে
      allow read: if isOwner(userId) || isAnyAdmin();

      // ✅ FIX: নতুন user নিজের doc তৈরি করতে পারবে
      //    শর্ত: নিজের uid হতে হবে, role field থাকতে পারবে না
      allow create: if request.auth != null &&
        request.auth.uid == userId &&
        isReasonableSize() &&
        !('role' in request.resource.data);

      // নিজের doc update করতে পারবে — কিন্তু role field পরিবর্তন করতে পারবে না
      allow update: if (isOwner(userId) &&
        !('role' in request.resource.data.diff(resource.data).affectedKeys())) ||
        isSuperAdmin();

      // Delete: superadmin only
      allow delete: if isSuperAdmin();
    }

    // ─────────────────────────────────────────────────────────
    //  adminProfiles collection
    // ─────────────────────────────────────────────────────────
    match /adminProfiles/{adminId} {
      allow read: if isOwner(adminId) || isAnyAdmin();
      allow update: if isOwner(adminId) || isSuperAdmin();
      allow create, delete: if isSuperAdmin();
    }

    // ─────────────────────────────────────────────────────────
    //  editRequests collection
    // ─────────────────────────────────────────────────────────
    match /editRequests/{requestId} {
      allow read: if isAuth() &&
        (resource.data.get('requestedBy','') == request.auth.uid || isAnyAdmin());

      allow create: if isAuth() && isReasonableSize() &&
        request.resource.data.get('status','') == 'pending' &&
        request.resource.data.get('requestedBy','') == request.auth.uid;

      allow update: if isAdmin() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status','approvedAt','approvedBy','rejectedAt','rejectedBy',
                    '_notifiedUser','_notifiedUserRejected','updatedAt']);

      allow delete: if isSuperAdmin();
    }

    // ─────────────────────────────────────────────────────────
    //  notifications collection
    // ─────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuth() &&
        (resource.data.get('uid','') == request.auth.uid || isAnyAdmin());

      allow create: if isAdmin() && isReasonableSize();

      allow update: if isAuth() &&
        resource.data.get('uid','') == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read','readAt']);

      allow delete: if isSuperAdmin();
    }

    // ─────────────────────────────────────────────────────────
    //  announcements collection
    // ─────────────────────────────────────────────────────────
    match /announcements/{annId} {
      allow read: if isAuth();
      allow create: if isAdmin() && isReasonableSize();
      allow update, delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    //  passwordResets collection
    // ─────────────────────────────────────────────────────────
    match /passwordResets/{docId} {
      allow read: if isAuth() && (
        request.auth.token.email.split('@')[0] == docId.lower() ||
        isAdmin()
      );

      allow create: if isAdmin() && isReasonableSize();

      allow update: if (isAdmin() && isReasonableSize()) ||
        (isAuth() &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['used','usedAt']));

      allow delete: if isSuperAdmin();
    }

    // ─────────────────────────────────────────────────────────
    //  auditLogs collection
    // ─────────────────────────────────────────────────────────
    match /auditLogs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isAuth() && isReasonableSize();
      allow update, delete: if false;
    }

    // ─────────────────────────────────────────────────────────
    //  fieldClearLog
    // ─────────────────────────────────────────────────────────
    match /fieldClearLog/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update, delete: if false;
    }

    // ─────────────────────────────────────────────────────────
    //  Default deny
    // ─────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
